# Frontend Environment Variables

# Google OAuth 2.0 Client ID (same as backend GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend API URL — set to your Render production URL in production
VITE_BACKEND_URL=http://localhost:5000
# Example production: VITE_BACKEND_URL=https://your-app.onrender.com
