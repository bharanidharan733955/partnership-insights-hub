# Backend Environment Variables

# Server Configuration
PORT=5000

# Database Configuration
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.mongodb.net/?appName=YourApp

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-secret-key-change-in-production

# Default Analyst User (created on first run if none exists)
ANALYST_EMAIL=analyst@enterprise.com
ANALYST_PASSWORD=password123
ANALYST_NAME=Global Analyst

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend URL (for CORS) — set to your Vercel production URL in production
FRONTEND_URL=http://localhost:8080
# Example production: FRONTEND_URL=https://your-app.vercel.app

# Backend URL (used by render.yaml and for reference)
BACKEND_URL=http://localhost:5000
# Example production: BACKEND_URL=https://your-app.onrender.com

