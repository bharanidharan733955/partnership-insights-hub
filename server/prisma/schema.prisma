generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(PARTNER)
  partnerId String?
  branchId  String?
  partner   Partner? @relation(fields: [partnerId], references: [id])
  branch    Branch?  @relation(fields: [branchId], references: [id])
  auditLogs AuditLog[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ANALYST
  PARTNER
}

model Partner {
  id        String   @id @default(uuid())
  name      String   @unique
  branches  Branch[]
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id           String        @id @default(uuid())
  name         String
  location     String
  partnerId    String
  partner      Partner       @relation(fields: [partnerId], references: [id])
  salesRecords SalesRecord[]
  users        User[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model SalesRecord {
  id           String   @id @default(uuid())
  date         DateTime
  productName  String
  quantity     Int
  salesAmount  Float
  profit       Float
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([date, branchId, productName])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  details   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  timestamp DateTime @default(now())
}
